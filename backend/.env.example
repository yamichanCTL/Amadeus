# Copy to backend/.env and adapt only environment-specific values.
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
SECRET_KEY=change-me-in-production

# Relative paths are resolved independently of the shell working directory.
PROJECT_ROOT=..
FRONTEND_DESKTOP_DIR=../frontend/desktop
DATABASE_URL=sqlite+aiosqlite:///data/asr.db
MODELS_DIR=models
AUDIO_UPLOAD_DIR=data/uploads
TRANSCRIPT_DIR=data/transcripts
ARCHIVE_DIR=data/archive
TTS_DATA_DIR=tts

# External source trees are environment-specific. Leave unused integrations empty.
SENSEVOICE_SRC_PATH=
FIREREDASR2_SRC_PATH=app/core/asr/engines/FireRedASR2S
GPT_SOVITS_DIR=

DEFAULT_ENGINE=sensevoice
DEFAULT_STREAM_ENGINE=x-asr
DEFAULT_SENSEVOICE_DEVICE=cuda:0
DEFAULT_FIREREDASR2_DEVICE=cuda
FIREREDASR2_MODEL_DIR=models/fireredasr2/FireRedASR2-AED

# X-ASR model path is relative to backend/. Multiple CUDA roots use the OS path separator.
X_ASR_MODEL_DIR=../thirdparty/X-ASR/X-ASR-zh-en/deployment/models/chunk-960ms-model
DEFAULT_X_ASR_PROVIDER=cuda
X_ASR_CUDA_LIBRARY_PATH=
X_ASR_LIBSTDCPP_PATH=
X_ASR_ISOLATE_CUDA=true
X_ASR_WORKER_TIMEOUT_SEC=90

TRANSCRIBE_TIMEOUT_SEC=20
ASR_INFERENCE_SCHEDULER_ENABLED=true
ASR_INFERENCE_MAX_BATCH_ITEMS=4
ASR_INFERENCE_MAX_WAIT_MS=100
ASR_LONG_AUDIO_CHUNK_SEC=60
ALLOWED_ORIGINS=["*"]
